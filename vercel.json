{
    "regions": ["sin1"],
    "builds": [
        {
            "src": "main.py",
            "use": "@vercel/python"
        },
        {
            "src": "api/cron.py",
            "use": "@vercel/python"
        },
        {
            "src": "api/render-card.js",
            "use": "@vercel/node",
            "config": {
                "maxLambdaSize": "250mb",
                "includeFiles": "node_modules/@sparticuz/chromium/bin/**"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/cron",
            "dest": "api/cron.py"
        },
        {
            "src": "/api/render-card",
            "dest": "api/render-card.js"
        },
        {
            "src": "/webhook/(.*)",
            "dest": "main.py"
        },
        {
            "src": "/(.*)",
            "dest": "main.py"
        }
    ],
    "crons": [
        {
            "path": "/api/cron",
            "schedule": "0 1 * * *"
        }
    ],
    "env": {
        "ENVIRONMENT": "production"
    }
}